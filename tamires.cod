import requests
import webbrowser

def consultar_cep(cep):
    url = f"https://viacep.com.br/ws/{cep}/json/"
    resposta = requests.get(url)

    if resposta.status_code == 200:
        dados = resposta.json()

        if "erro" not in dados:
            html = f"""
            <html>
            <head>
            <title>Consulta de CEP</title>
            </head>
            <body>
            <h1>Resultado do CEP</h1>
            <p><b>CEP:</b> {dados.get('cep', '')}</p>
            <p><b>Rua:</b> {dados.get('logradouro', '')}</p>
            <p><b>Bairro:</b> {dados.get('bairro', '')}</p>
            <p><b>Cidade:</b> {dados.get('localidade', '')}</p>
            <p><b>Estado:</b> {dados.get('uf', '')}</p>
            </body>
            </html>
            """

            # Salva o arquivo
            with open("resultado.html", "w", encoding="utf-8") as arquivo:
                arquivo.write(html)
            # Abre no navegador (Chrome padrão)
            webbrowser.open("resultado.html")
        else:
            print("CEP não encontrado!")
    else:
        print("Erro na requisição:", resposta.status_code)

def main():
    cep = input("Digite o CEP: ").replace("-", "").strip()
    if len(cep) != 8 or not cep.isdigit():
        print("CEP inválido. Por favor, digite um CEP válido (8 dígitos).")
    else:
        consultar_cep(cep)

if __name__ == "__main__":
    main()
